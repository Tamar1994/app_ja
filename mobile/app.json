{
  "expo": {
    "name": "Já!",
    "slug": "ja-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B00"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ja.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "O Já! precisa da sua localização para encontrar profissionais próximos.",
        "NSLocationAlwaysUsageDescription": "O Já! usa sua localização para mostrar sua posição aos clientes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B00"
      },
      "package": "com.ja.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.ACCESS_NOTIFICATION_POLICY"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FF6B00",
          "defaultChannel": "job-alerts",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "O Já! precisa da sua localização para conectar você com profissionais próximos."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "fbebee6b-64e1-48f0-bc40-67bbec6ab531"
      }
    }
  }
}
